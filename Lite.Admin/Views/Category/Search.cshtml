@model PagedResult<Category>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount.ToString("N0")</strong> loại hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên loại hàng</th>
                    <th>Mô tả</th>
                    <th>Trạng thái</th>
                    <th class="text-center" style="width:120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr class="@(item.IsHidden ? "table-secondary text-muted" : "")">
                        <td>@item.CategoryName</td>
                        <td>@item.Description</td>
                        <td>
                            @if (item.IsHidden)
                            {
                                <span class="badge bg-secondary">Đang ẩn</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hiển thị</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Category/Edit/@item.CategoryID" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="/Category/ToggleHidden/@item.CategoryID" class="d-inline">
                                <button type="submit" class="btn btn-sm @(item.IsHidden ? "btn-success" : "btn-warning")" title="@(item.IsHidden ? "Hiện" : "Ẩn")">
                                    <i class="bi @(item.IsHidden ? "bi-eye" : "bi-eye-slash")"></i>
                                </button>
                            </form>
                            <a href="~/Category/Delete/@item.CategoryID" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active">
                        <a class="page-link">@p.Page</a>
                    </li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item">
                        <a class="page-link">...</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>

