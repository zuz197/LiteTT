@using Microsoft.AspNetCore.Http
@{
    ViewBag.Title = "Xác thực OTP";
    Layout = null;
}

<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
</head>
<body class="login-page" style="min-height:100vh;">
<div class="login-box" style="margin:auto;padding-top:80px;">
    <div class="card card-outline card-primary">
        <div class="card-header text-center">
            <h4 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Xác thực OTP</h4>
        </div>
        <div class="card-body">
            <p class="text-center text-muted mb-3">
                Mã OTP đã được gửi về email của bạn.<br />
                <small>Mã có hiệu lực trong <strong>5 phút</strong>.</small>
            </p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error
                </div>
            }

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-1"></i>@TempData["Message"]
                </div>
            }

            <form asp-action="VerifyOtp" method="post">
                <div class="input-group mb-3">
                    <input type="text"
                           name="otp"
                           class="form-control text-center"
                           placeholder="Nhập mã 6 số"
                           maxlength="6"
                           autocomplete="one-time-code"
                           autofocus
                           style="font-size:24px;letter-spacing:8px;font-weight:bold;" />
                    <div class="input-group-text">
                        <i class="bi bi-key"></i>
                    </div>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-lg me-1"></i> Xác nhận
                    </button>
                </div>
            </form>

            <div class="text-center">
                <form asp-action="ResendOtp" method="post" class="d-inline">
                    <button type="submit" class="btn btn-link btn-sm text-muted">
                        <i class="bi bi-arrow-clockwise me-1"></i>Gửi lại mã OTP
                    </button>
                </form>
                <span class="text-muted mx-2">|</span>
                <a asp-action="Login" class="btn btn-link btn-sm text-muted">
                    <i class="bi bi-arrow-left me-1"></i>Quay lại đăng nhập
                </a>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    document.querySelector('input[name="otp"]').addEventListener('input', function() {
        this.value = this.value.replace(/\D/g, '').slice(0, 6);
    });
</script>
</body>
</html>
