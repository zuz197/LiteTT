@model Lite.Admin.Models.OrderShippingFormModel
@{
    Layout = null;
    string? errorMessage = ViewBag.ErrorMessage as string;
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="modal-header text-bg-warning">
        <strong class="modal-title">Không thể giao hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-warning d-flex align-items-center mb-0">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @errorMessage
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </button>
    </div>
}
else
{
    <form asp-controller="Order" asp-action="Shipping" asp-route-id="@Model.OrderID" method="post">
        @Html.AntiForgeryToken()
        <div class="modal-header text-bg-info">
            <strong class="modal-title">Chọn người giao hàng</strong>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
            <div class="row">
                <div class="col-12">
                    <label class="form-label">Người giao hàng</label>
                    <select name="shipperID" class="form-select" required>
                        <option value="">-- Chọn người giao hàng --</option>
                        @foreach (var s in Model.Shippers)
                        {
                            <option value="@s.ShipperID">@s.ShipperName</option>
                        }
                    </select>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-bicycle"></i> Giao hàng
            </button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        </div>
    </form>
}
