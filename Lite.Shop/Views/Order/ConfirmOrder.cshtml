@{
    ViewBag.Title = "Xác nhận đặt hàng";
    var customer = ViewBag.Customer as Lite.Shop.Models.Customer;
    var cartItems = ViewBag.CartItems as List<Lite.Shop.Models.CartItem>;
    decimal total = cartItems?.Sum(i => i.Price * i.Quantity) ?? 0;
}

<h3 class="text-primary mb-4">📋 Xác nhận đặt hàng</h3>

<div class="card mb-4">
    <div class="card-header fw-bold">👤 Thông tin giao hàng</div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-6">
                <span class="text-muted">Họ tên:</span>
                <strong class="ms-2">@(customer?.CustomerName ?? "-")</strong>
            </div>
            <div class="col-md-6">
                <span class="text-muted">Số điện thoại:</span>
                <strong class="ms-2">@(customer?.Phone ?? "-")</strong>
            </div>
            <div class="col-md-6">
                <span class="text-muted">Địa chỉ:</span>
                <strong class="ms-2">@(customer?.Address ?? "-")</strong>
            </div>
            <div class="col-md-6">
                <span class="text-muted">Tỉnh / Thành:</span>
                <strong class="ms-2">@(customer?.Province ?? "-")</strong>
            </div>
        </div>

        @if (string.IsNullOrWhiteSpace(customer?.Address) || string.IsNullOrWhiteSpace(customer?.Phone))
        {
            <div class="alert alert-warning mt-3 mb-0">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Thông tin giao hàng chưa đầy đủ.
                <a asp-controller="Account" asp-action="Profile" class="alert-link">Cập nhật ngay</a>
            </div>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-bold">🛍 Sản phẩm đặt mua</div>
    <div class="card-body p-0">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-primary text-center">
                <tr>
                    <th>Sản phẩm</th>
                    <th style="width:150px">Giá</th>
                    <th style="width:100px">Số lượng</th>
                    <th style="width:160px">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in cartItems!)
                {
                    <tr>
                        <td><strong>@item.ProductName</strong></td>
                        <td class="text-end">@item.Price.ToString("N0") đ</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end text-danger fw-bold">
                            @((item.Price * item.Quantity).ToString("N0")) đ
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="text-end mb-4">
    <h4 class="text-danger">Tổng tiền: @total.ToString("N0") đ</h4>
</div>

<div class="d-flex justify-content-between">
    <a asp-controller="Cart" asp-action="Index" class="btn btn-secondary">
        ← Quay lại giỏ hàng
    </a>

    <form asp-controller="Order" asp-action="Checkout" method="post">
        <button type="submit" class="btn btn-success btn-lg px-4">
             Xác nhận đặt hàng
        </button>
    </form>
</div>
