<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div class="card shadow-lg p-4" style="width:400px; border-radius:15px;">

        <h3 class="text-center mb-4 text-primary fw-bold">
            🔑 Quên mật khẩu
        </h3>

        <p class="text-muted text-center small mb-4">
            Nhập email đã đăng ký. Chúng tôi sẽ gửi mã OTP để đặt lại mật khẩu.
        </p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center py-2">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control"
                       placeholder="Nhập email đã đăng ký..." required autofocus />
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-primary rounded-pill">
                    Gửi mã OTP
                </button>
            </div>
        </form>

        <div class="text-center mt-3">
            <small>
                <a asp-controller="Account" asp-action="Login" class="text-muted">
                    ← Quay lại đăng nhập
                </a>
            </small>
        </div>
    </div>
</div>
